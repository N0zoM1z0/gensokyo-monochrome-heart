; Engine configuration file.
; Edit through reviewed changes or the Godot editor; do not silently change foundation constraints.

config_version=5

[application]

config/name="Gensokyo: Monochrome Heart"
config/version="0.1.0-dev"
run/main_scene="res://src/presentation/shell/Main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/show_image=false

[autoload]

SettingsService="*res://src/autoload/SettingsService.gd"
LocalizationService="*res://src/autoload/LocalizationService.gd"
ContentDB="*res://src/autoload/ContentDB.gd"
GameKernel="*res://src/autoload/GameKernel.gd"
SaveService="*res://src/autoload/SaveService.gd"
InputGlyphService="*res://src/autoload/InputGlyphService.gd"
FocusRouter="*res://src/autoload/FocusRouter.gd"
AccessibilityState="*res://src/autoload/AccessibilityState.gd"
UiThemeRegistry="*res://src/autoload/UiThemeRegistry.gd"
LocalizationMeasure="*res://src/autoload/LocalizationMeasure.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"

[gmh]

build/channel="dev"
content/revision="2026.07.15.2"
save/schema_version=2

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=false
textures/canvas_textures/default_texture_filter=0
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true

[physics]

common/physics_interpolation=false
