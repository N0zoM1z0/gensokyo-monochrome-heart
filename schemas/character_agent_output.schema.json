{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "character_agent_output.schema.json",
  "title": "Monochrome Heart Character Beat",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent",
    "spoken_line_en",
    "spoken_line_ja",
    "nonverbal",
    "state_suggestion"
  ],
  "properties": {
    "intent": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "spoken_line_en": {
      "type": "string",
      "maxLength": 500
    },
    "spoken_line_ja": {
      "type": "string",
      "maxLength": 500
    },
    "nonverbal": {
      "type": "string",
      "maxLength": 240
    },
    "action": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 240
    },
    "memory_tag": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-z0-9_.-]*$"
    },
    "state_suggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust",
        "ease",
        "respect",
        "spark",
        "strain"
      ],
      "properties": {
        "trust": {
          "type": "integer",
          "minimum": -1,
          "maximum": 1
        },
        "ease": {
          "type": "integer",
          "minimum": -1,
          "maximum": 1
        },
        "respect": {
          "type": "integer",
          "minimum": -1,
          "maximum": 1
        },
        "spark": {
          "type": "integer",
          "minimum": -1,
          "maximum": 1
        },
        "strain": {
          "type": "integer",
          "minimum": -1,
          "maximum": 1
        }
      }
    }
  }
}
