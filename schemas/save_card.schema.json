{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gensokyo-monochrome-heart.invalid/schemas/save_card.schema.json",
  "title": "Lightweight Save Card",
  "type": "object",
  "required": [
    "format", "slot_id", "profile_id", "chapter_id", "day", "time_slot", "location_id",
    "play_time_seconds", "visible_character_ids", "route_completion_ids", "accessibility_preset_id",
    "screenshot_path", "game_version", "save_schema_version", "saved_utc"
  ],
  "properties": {
    "format": {"const": "gmh_save_card"},
    "slot_id": {"enum": ["manual_01", "manual_02", "manual_03", "auto_day", "auto_event", "auto_mode"]},
    "profile_id": {"type": "string", "pattern": "^p[0-9]{2,}$"},
    "chapter_id": {"type": "string", "pattern": "^chapter\\."},
    "day": {"type": "integer", "minimum": 1},
    "time_slot": {"enum": ["morning", "day", "dusk", "night"]},
    "location_id": {"type": "string", "pattern": "^loc\\."},
    "play_time_seconds": {"type": "integer", "minimum": 0},
    "visible_character_ids": {"type": "array", "items": {"type": "string", "pattern": "^char\\."}},
    "route_completion_ids": {"type": "array", "items": {"type": "string"}},
    "accessibility_preset_id": {"type": "string"},
    "screenshot_path": {"type": "string"},
    "game_version": {"type": "string", "minLength": 1},
    "save_schema_version": {"type": "integer", "minimum": 1},
    "saved_utc": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
