{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gensokyo-monochrome-heart.invalid/schemas/ui_localization.schema.json",
  "title": "UI Localization Catalog",
  "type": "object",
  "required": ["schema", "strings"],
  "properties": {
    "schema": {"const": "gmh-ui-localization-v1"},
    "strings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "en", "ja"],
        "properties": {
          "key": {"type": "string", "pattern": "^[a-z][a-z0-9_.]+$"},
          "en": {"type": "string", "minLength": 1},
          "ja": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
