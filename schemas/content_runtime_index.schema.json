{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gensokyo-monochrome-heart.invalid/schemas/content_runtime_index.schema.json",
  "title": "Generated Runtime Content Index",
  "type": "object",
  "required": ["schema", "content_revision", "content_hash", "counts", "ids", "dependencies"],
  "properties": {
    "schema": {"const": "gmh-runtime-content-index-v2"},
    "content_revision": {"type": "string", "minLength": 1},
    "content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "counts": {
      "type": "object",
      "required": ["characters", "locations", "events", "dialogue_beats", "localization", "music_cues", "event_nodes", "seasonal_events"],
      "properties": {
        "characters": {"type": "integer", "minimum": 0},
        "locations": {"type": "integer", "minimum": 0},
        "events": {"type": "integer", "minimum": 0},
        "dialogue_beats": {"type": "integer", "minimum": 0},
        "localization": {"type": "integer", "minimum": 0},
        "music_cues": {"type": "integer", "minimum": 0},
        "event_nodes": {"type": "integer", "minimum": 0},
        "seasonal_events": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "ids": {
      "type": "object",
      "required": ["characters", "locations", "events", "dialogue_beats", "localization", "music_cues", "seasonal_events"],
      "properties": {
        "characters": {"type": "array", "items": {"type": "string", "pattern": "^char\\."}},
        "locations": {"type": "array", "items": {"type": "string", "pattern": "^loc\\."}},
        "events": {"type": "array", "items": {"type": "string", "pattern": "^evt\\."}},
        "dialogue_beats": {"type": "array", "items": {"type": "string", "pattern": "^beat\\."}},
        "localization": {"type": "array", "items": {"type": "string", "minLength": 3}},
        "music_cues": {"type": "array", "items": {"type": "string", "pattern": "^mus_"}},
        "seasonal_events": {"type": "array", "items": {"type": "string", "pattern": "^season\\."}}
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "kind"],
        "properties": {
          "source": {"type": "string", "minLength": 1},
          "target": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
