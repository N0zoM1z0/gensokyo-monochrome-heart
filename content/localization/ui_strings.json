	{"key": "ui.danmaku.missing_minute.result.assist_clear.reason", "en": "THE WARNING CLOCK STAYS VISIBLE. THE STORY CONTINUES.", "ja": "予告時計を表示したまま、物語は続く。"},
	{"key": "ui.danmaku.missing_minute.result.assist_clear.title", "en": "ASSISTED RELEASE", "ja": "アシストで時を解放"},
	{"key": "ui.danmaku.missing_minute.result.clear.reason", "en": "ALL THREE KNIFE PATTERNS RELEASED WITHOUT TAKING THE MINUTE.", "ja": "一分を奪われず、三つのナイフ陣がほどけた。"},
	{"key": "ui.danmaku.missing_minute.result.clear.title", "en": "MINUTE RECOVERED", "ja": "一分を取り戻した"},
	{"key": "ui.danmaku.missing_minute.result.loss.reason", "en": "THE MINUTE STAYED MISSING. ACCEPTING IT STILL MOVES THE STORY.", "ja": "一分は消えたまま。受け入れても物語は進む。"},
	{"key": "ui.danmaku.missing_minute.result.loss.title", "en": "MINUTE MISSED", "ja": "一分を逃した"},
	{"key": "ui.danmaku.missing_minute.teach.clock_hands", "en": "READ THE HAND'S ANGLE BEFORE THE RING OPENS.", "ja": "輪が開く前に、針の角度を読む。"},
	{"key": "ui.danmaku.missing_minute.teach.lattice", "en": "FIND THE EMPTY SLOT. HOLD SHOT TO BREAK THE CLOCK.", "ja": "空いた位置へ。射撃を長押しして時計を壊す。"},
	{"key": "ui.danmaku.missing_minute.teach.release", "en": "FROZEN KNIVES MOVE ONLY AFTER THE WARNING ENDS.", "ja": "止まったナイフは予告の後にだけ動く。"},
	{"key": "ui.danmaku.missing_minute.title", "en": "THE MISSING MINUTE", "ja": "消えた一分"},
	{"key": "ui.danmaku.photo.capture", "en": "SNAP", "ja": "撮影"},
	{"key": "ui.danmaku.photo.need_margin", "en": "NEED 25%", "ja": "25% 必要"},
	{"key": "ui.danmaku.photo.paused", "en": "HEADLINE CHASE PAUSED", "ja": "見出し追跡を中断中"},
