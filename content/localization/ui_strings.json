	{"key": "ui.danmaku.photo.phase.keyword_gale", "en": "KEYWORDS RIDE THE GALE", "ja": "見出し語が風に乗る"},
	{"key": "ui.danmaku.photo.phase.published_path", "en": "THE PUBLISHED SAFE PATH", "ja": "掲載された安全路"},
	{"key": "ui.danmaku.photo.ready", "en": "READY", "ja": "撮影可"},
	{"key": "ui.danmaku.photo.result.assist_clear.reason", "en": "THE FRAME STAYS VISIBLE. THE STORY CONTINUES WITHOUT A PERFECT SHOT.", "ja": "取景枠を表示したまま、完璧な一枚なしでも物語は続く。"},
	{"key": "ui.danmaku.photo.result.assist_clear.title", "en": "ASSISTED EXPOSURE", "ja": "撮影アシスト"},
	{"key": "ui.danmaku.photo.result.clear.reason", "en": "THREE WIND PATTERNS WERE RECORDED WITHOUT MAKING THE HEADLINE TRUE.", "ja": "見出しを現実にせず、三つの風の弾幕を記録した。"},
	{"key": "ui.danmaku.photo.result.clear.title", "en": "FRAME WITHHELD", "ja": "未掲載の一枚"},
	{"key": "ui.danmaku.photo.result.loss.reason", "en": "THE PUBLISHED ROUTE HELD. ACCEPTING THE MISS STILL MOVES THE STORY.", "ja": "掲載された道筋は残った。撮り逃しても物語は進む。"},
	{"key": "ui.danmaku.photo.result.loss.title", "en": "HEADLINE AHEAD", "ja": "見出しが先回り"},
	{"key": "ui.danmaku.photo.teach.future_frame", "en": "CLEAR 3 WAVES. GRAZE FOR MARGIN. FRAME BULLETS; SNAP.", "ja": "三波を越える。弾にかすって余白を得る。弾を枠に入れ、撮影。"},
	{"key": "ui.danmaku.photo.teach.keyword_gale", "en": "CAPTURE BULLETS INSIDE THE FRAME, NOT THE PERSON BEHIND THEM.", "ja": "枠内の弾を撮る。その向こうの人は撮らない。"},
	{"key": "ui.danmaku.photo.teach.published_path", "en": "THE PRINTED SAFE LANE MOVED. COMPOSE YOUR OWN GAP.", "ja": "紙面の安全路は動いた。自分の隙間を切り取る。"},
	{"key": "ui.danmaku.photo.title", "en": "TOMORROW'S HEADLINE", "ja": "明日の見出し"},
	{"key": "ui.danmaku.photo.visual.captured", "en": "BULLETS CAPTURED", "ja": "弾を記録"},
	{"key": "ui.danmaku.photo.visual.empty", "en": "EMPTY FRAME", "ja": "空の枠"},
