	{"key": "ui.exploration.sdm.note.clock", "en": "THE CORRIDOR CLOCK LOSES THE SAME THREE MINUTES.", "ja": "廊下の時計は同じ三分を失い続けている。"},
	{"key": "ui.exploration.sdm.note.door", "en": "THE KITCHEN DOOR OPENS BEFORE ITS HANDLE MOVES.", "ja": "厨房の扉は取っ手が動く前に開く。"},
	{"key": "ui.exploration.sdm.note.pass", "en": "ONE EMPTY PLACE WAITS AT THE KITCHEN PASS.", "ja": "料理受けには一つ分の空きが待っている。"},
	{"key": "ui.exploration.sdm.note.sakuya", "en": "SAKUYA WATCHES THE CLOCK'S REFLECTION, NOT ITS HANDS.", "ja": "咲夜は針でなく、時計の映り込みを見ている。"},
	{"key": "ui.exploration.sdm.note.tray", "en": "THE TRAY RETURNS TO ITS MARK WHEN THE CLOCK TICKS.", "ja": "時計が刻むたび、盆は印の位置へ戻る。"},
	{"key": "ui.exploration.sdm.objective.complete", "en": "THE RESETTING TRAY LEADS TO SAKUYA.", "ja": "戻る盆の先に咲夜がいる。"},
