/.godot/
/.idea/
/.vscode/
/build/
/dist/
/reports/generated/
/tests/screenshots/generated/*
!/tests/screenshots/generated/.gdignore
/preparation/

# Godot mistakes the reviewed data tables for translation catalogs. These
# auto-import products are disposable; the source CSV files remain canonical.
/content/**/*.csv.import
/content/**/*.translation

*.log
*.py[cod]
*.tmp
*.swp
*~
__pycache__/
